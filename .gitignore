# ============================================================
# AI-Powered Job Application Assistant — .gitignore
# ============================================================

# ─── Python / Django (backend) ──────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
env/
.venv/
.env/
ENV/

# Django specifics
*.sqlite3
db.sqlite3
staticfiles/
backend/media/uploads/

# Uploaded interview recordings
*.wav
*.mp3
*.mp4
*.webm

# ─── Environment / Secrets ──────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
backend/.env

# ─── Node / React (frontend) ────────────────────────────────
node_modules/
/.pnp
.pnp.js
/coverage
/build
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── IDE / Editor ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code local-only settings (per-machine permission approvals)
.claude/settings.local.json
.claude/*.lock

# ─── OS ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs ───────────────────────────────────────────────────
*.log
logs/

# ─── Misc ───────────────────────────────────────────────────
*.bak
*.tmp
*.orig

# Devpost submission assets (screenshots, demo-account scripts) — not project code
/project-media/
